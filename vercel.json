{
  "crons": [
    {
      "path": "/api/cron/policy-refresh",
      "schedule": "17 9 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/projectoverview",
      "destination": "/index.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/index.html"
    }
  ]
}
