    "type" : "paragraph",
    "id" : 7,
    "page number" : 1,
    "bounding box" : [ 36.0, 567.035, 569.474, 666.602 ],
    "font" : "ArialMT",
    "font size" : 11.0,
    "text color" : "[0.0, 0.0, 0.0]",
    "content" : "Educational systems and institutions are increasingly attending to the role of Artificial Intelligence (AI) in the activities of employees and students. AI broadly encompasses tools that draw upon data sets to detect patterns, create models, and generate new content and outputs. There is an ongoing explosion in the creation and application of AI technologies across all dimensions of modern life, including education. The purpose of this document is to clarify the role of AI in the Tuscaloosa City Schools and the overlap with existing policy. This document is intended to be a living document that will be modified as our experience and understanding of the role of AI in education evolves."
  }, {
    "type" : "paragraph",
    "id" : 8,
    "page number" : 1,
    "bounding box" : [ 36.0, 537.943, 75.11, 550.232 ],
    "font" : "Arial-ItalicMT",
    "font size" : 11.0,
    "text color" : "[0.0, 0.0, 0.0]",
    "content" : "Position"
  }, {
    "type" : "list",
    "id" : 9,
    "level" : "1",
    "page number" : 1,
    "bounding box" : [ 54.0, 436.119, 575.068, 535.686 ],
    "numbering style" : "unordered",
    "number of list items" : 3,
    "list items" : [ {
      "type" : "list item",
      "page number" : 1,
      "bounding box" : [ 54.0, 494.304, 570.575, 535.686 ],
      "font" : "ArialMT",
      "font size" : 11.0,
      "text color" : "[0.0, 0.0, 0.0]",
      "content" : "● Tuscaloosa City Schools employees and students can use tools, applications, and resources that incorporate AI for instructional, learning, logistical, and operational activities where such tools meet our standards for data privacy, security, and quality practice.",
      "kids" : [ ]
    }, {
      "type" : "list item",
      "page number" : 1,
      "bounding box" : [ 54.0, 465.212, 528.631, 492.047 ],
      "font" : "ArialMT",
      "font size" : 11.0,
      "text color" : "[0.0, 0.0, 0.0]",
      "content" : "● Tuscaloosa City Schools employees and students will provide proper acknowledgement of the contribution of AI to the creation of learning, instructional, communication, and other products.",
      "kids" : [ ]
    }, {
      "type" : "list item",
      "page number" : 1,
      "bounding box" : [ 54.0, 436.119, 575.068, 462.954 ],
      "font" : "ArialMT",
      "font size" : 11.0,
      "text color" : "[0.0, 0.0, 0.0]",
      "content" : "● Tuscaloosa City Schools employees and students will adhere to existing academic honesty policies and procedures as outlined in the Code of Conduct.",
      "kids" : [ ]
    } ]
