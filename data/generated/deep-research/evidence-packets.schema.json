{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AIED Policy Deep Research Evidence Packet",
  "type": "object",
  "required": [
    "jurisdiction_id",
    "state_abbr",
    "reviewed_at",
    "investigation_reason",
    "summary",
    "candidate_sources",
    "field_level_findings",
    "approval_recommendation",
    "recommended_record",
    "gold_record"
  ],
  "properties": {
    "jurisdiction_id": { "type": "string" },
    "state_abbr": { "type": "string" },
    "reviewed_at": { "type": "string" },
    "investigation_reason": {
      "type": "array",
      "items": { "type": "string" }
    },
    "summary": { "type": "string" },
    "candidate_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url", "authority_level", "source_type", "selected"],
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string" },
          "authority_level": { "type": "string" },
          "source_type": { "type": "string" },
          "selected": { "type": "boolean" },
          "why_it_matters": { "type": ["string", "null"] }
        }
      }
    },
    "field_level_findings": {
      "type": "object",
      "properties": {
        "ai_use_allowed": { "$ref": "#/$defs/fieldFinding" },
        "assessment_policy": { "$ref": "#/$defs/fieldFinding" },
        "privacy_policy": { "$ref": "#/$defs/fieldFinding" },
        "teacher_pd_support": { "$ref": "#/$defs/fieldFinding" },
        "implementation_stage": { "$ref": "#/$defs/fieldFinding" }
      },
      "required": [
        "ai_use_allowed",
        "assessment_policy",
        "privacy_policy",
        "teacher_pd_support",
        "implementation_stage"
      ]
    },
    "conflicts_found": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "approval_recommendation": {
      "type": "object",
      "required": ["approval_route", "confidence", "rationale"],
      "properties": {
        "approval_route": {
          "type": "string",
          "enum": ["auto_approve", "sample_audit", "human_review"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rationale": { "type": "string" }
      }
    },
    "recommended_record": {
      "type": "object"
    },
    "gold_record": {
      "type": "object"
    }
  },
  "$defs": {
    "fieldFinding": {
      "type": "object",
      "required": ["value", "rationale"],
      "properties": {
        "value": { "type": ["integer", "null"] },
        "rationale": { "type": "string" },
        "evidence_quote": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] }
      }
    }
  }
}
