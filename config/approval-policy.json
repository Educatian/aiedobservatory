{
  "version": "0.1.0",
  "routing_policy": {
    "auto_approve": {
      "minimum_confidence": 0.9,
      "requires_strong_primary_source": true,
      "requires_evidence_for_all_scored_fields": true,
      "requires_no_unresolved_conflict": true,
      "forbidden_source_levels": ["secondary_reporting_only", "press_release_only"]
    },
    "sample_audit": {
      "minimum_confidence": 0.75,
      "maximum_confidence": 0.89,
      "requires_evidence_for_core_fields": true,
      "allows_minor_ambiguity": true
    },
    "human_review": {
      "triggers": [
        "confidence_below_threshold",
        "missing_citation",
        "source_conflict",
        "policy_stage_ambiguous",
        "outdated_primary_source",
        "verifier_rejection"
      ]
    }
  },
  "deep_research_escalation": {
    "triggers": [
      "weak_official_source",
      "citation_gap",
      "source_conflict",
      "update_suspected",
      "coverage_gap"
    ],
    "max_attempts_per_record": 2
  }
}
